{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "lang": {
      "default": "en",
      "type": "string",
      "enum": [
        "en",
        "zh"
      ]
    },
    "slug": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "redacted": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "author"
  ]
}